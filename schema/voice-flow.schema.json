{
  "$ref": "#/definitions/ConversationFlow",
  "definitions": {
    "ConversationFlow": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "const": "2.0"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "multiple_choice_single",
                  "multiple_choice_multiple",
                  "voice_input_single",
                  "voice_input_multiline",
                  "likert_scale",
                  "rating_scale",
                  "display_list"
                ]
              },
              "text": {
                "type": "string"
              },
              "choices": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "display": {
                      "type": "string",
                      "minLength": 1
                    },
                    "value": {
                      "type": "string"
                    },
                    "order": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "transitionTo": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "id",
                    "display",
                    "order"
                  ],
                  "additionalProperties": false
                }
              },
              "validation": {
                "type": "object",
                "properties": {
                  "minLength": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "maxLength": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  "pattern": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "scale": {
                "type": "object",
                "properties": {
                  "min": {
                    "type": "integer"
                  },
                  "max": {
                    "type": "integer"
                  },
                  "minLabel": {
                    "type": "string"
                  },
                  "maxLabel": {
                    "type": "string"
                  }
                },
                "required": [
                  "min",
                  "max"
                ],
                "additionalProperties": false
              },
              "required": {
                "type": "boolean"
              },
              "order": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "sectionId": {
                "type": "string"
              },
              "next": {
                "$ref": "#/definitions/ConversationFlow/properties/steps/items/properties/choices/items/properties/transitionTo"
              },
              "attachedOverlayId": {
                "type": "string"
              },
              "overlayImageUrl": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "id",
              "type",
              "text",
              "required",
              "order"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "metadata": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "preamble": {
              "type": "string"
            },
            "language": {
              "type": "string",
              "minLength": 2
            },
            "customStartMessage": {
              "type": "string"
            },
            "customEndMessage": {
              "type": "string"
            },
            "sections": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^SID"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string"
                  },
                  "order": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "id",
                  "name",
                  "order"
                ],
                "additionalProperties": false
              }
            },
            "voiceId": {
              "type": "string"
            },
            "vadParams": {
              "type": "object",
              "properties": {
                "stop_secs": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              },
              "additionalProperties": false
            },
            "maxSessionDuration": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "conversationSpeed": {
              "type": "string",
              "enum": [
                "slow",
                "normal",
                "fast"
              ]
            }
          },
          "required": [
            "preamble",
            "language"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "version",
        "steps",
        "metadata"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
